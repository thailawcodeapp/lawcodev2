rules_version = '2';

// Juris Voice cloud sync — least-privilege rules.
//
// • Every authenticated user can only access their own /users/{uid}/** tree.
// • Anonymous reads/writes are denied everywhere.
// • Device cap enforcement runs client-side (devices subcollection);
//   the rules just confirm the writer owns the document path.
//
// Deploy:
//   firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // The user's own root document and ALL nested subcollections/documents.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Default-deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
